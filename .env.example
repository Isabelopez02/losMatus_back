# Copia este archivo como .env y rellena tus valores reales.
# El archivo .env NO se sube a git (está en .gitignore).

# === Base de datos ===
# MySQL (usuario root sin contraseña). Debe existir la base de datos "matus".
DATABASE_URL=mysql+pymysql://root:@localhost/matus

# Alternativa sin instalar nada: SQLite
# DATABASE_URL=sqlite:///./database.db

SECRET_KEY=cambia-esta-clave

# URL base del backend (la usa el bot de Telegram)
API_BASE_URL=http://localhost:8000/api

# === Telegram ===
# Token que te entrega @BotFather
TELEGRAM_BOT_TOKEN=

# === IA (Groq - gratis) ===
# Consigue tu API key en https://console.groq.com/keys
# Si la dejas vacía, el sistema clasifica por reglas (sin IA externa).
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
